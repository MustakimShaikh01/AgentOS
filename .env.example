# Environment Configuration
# Copy to .env and fill in your values
# NEVER commit .env to git

# ── LLM Keys (add at least one) ──────────────────────────
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Security ──────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-256-bit-random-string

# ── App Settings ──────────────────────────────────────────
DEFAULT_MODEL=gemini-pro
DEBUG=false

# ── Database (matches docker-compose defaults) ────────────
DATABASE_URL=postgresql+asyncpg://agentos:agentos_secret@localhost:5432/agentos

# ── Redis (matches docker-compose defaults) ───────────────
REDIS_URL=redis://:redis_secret@localhost:6379/0

# ── LiteLLM ──────────────────────────────────────────────
LITELLM_BASE_URL=http://localhost:4000
